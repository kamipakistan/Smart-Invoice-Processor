POSTGRES_DB=fbr_sip_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=secretpassword
DATABASE_URL=postgresql+asyncpg://admin:secretpassword@localhost:5434/fbr_sip_db

REDIS_URL=redis://localhost:6380/0

MINIO_ENDPOINT=localhost:9010
MINIO_EXTERNAL_ENDPOINT=http://localhost:9010
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadminpassword
MINIO_BUCKET_RAW=raw-invoices
MINIO_BUCKET_PROCESSED=processed-invoices

# Provider Selection Options: gemini, openai, anthropic, ollama
AI_PROVIDER=gemini

# Gemini Model (Primary Vision AI)
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_KEY=

# OpenAI Model
OPENAI_MODEL=gpt-4o
OPENAI_API_KEY=

# Anthropic Model
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_API_KEY=

# Ollama Model
OLLAMA_MODEL=qwen3-vl:8b
OLLAMA_HOST=http://localhost:11434

# Ingestion Limits
MAX_UPLOAD_SIZE_MB=25
MAX_BATCH_FILES=200
BATCH_INGESTION_ROOT=/data/ingestion

# Docker Hub Image Repository
BACKEND_IMAGE=kamipakistan/varietyidentification:smartinvoiceprocessor-api-latest
FRONTEND_IMAGE=kamipakistan/varietyidentification:smartinvoiceprocessor-frontend-latest

# Langfuse Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:4001
LANGFUSE_PUBLIC_HOST=http://localhost:4001
